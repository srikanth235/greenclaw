{
  "name": "greenclaw",
  "version": "0.1.0",
  "private": true,
  "description": "Transparent inference proxy for OpenClaw — reduces token costs by 60%+ through intelligent task classification, context compaction, and model routing",
  "type": "module",
  "bin": {
    "greenclaw": "./packages/cli/dist/index.js"
  },
  "scripts": {
    "dev": "tsx packages/api/src/main.ts",
    "build": "pnpm -r build",
    "start": "node packages/api/dist/main.js",
    "typecheck": "pnpm -r typecheck",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "pnpm exec biome check packages tests",
    "lint:fix": "pnpm exec biome check --write packages tests",
    "format": "pnpm exec biome format --write .",
    "format:check": "pnpm exec biome format .",
    "prepare": "husky"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.6",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.0.0",
    "husky": "^9.1.7",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0",
    "zod": "^3.23.0"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "packageManager": "pnpm@9.12.0"
}
